# kb-mcp environment configuration
# Copy to .env and fill in the values you need.

# ---------------------------------------------------------------------------
# kb-mcp (optional — only needed for cross-project use)
# ---------------------------------------------------------------------------

# Path to collections.ron config file (overrides default discovery chain)
# KB_MCP_CONFIG=/path/to/collections.ron

# ---------------------------------------------------------------------------
# Researcher Agent — LLM provider (pick one)
# ---------------------------------------------------------------------------

# Anthropic (recommended for production)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (if not using VibeProxy)
# OPENAI_API_KEY=sk-...

# Ollama — no key needed, runs on host-gateway:11434

# VibeProxy — no key needed, runs on host-gateway:8317
# Install: https://github.com/automazeio/vibeproxy

# ---------------------------------------------------------------------------
# Researcher Agent — Web search
# ---------------------------------------------------------------------------

# Web search uses DuckDuckGo — no API key required.
